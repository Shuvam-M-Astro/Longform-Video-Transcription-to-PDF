# Environment Configuration Template
# Copy this file to .env and modify with your actual values

# Database Configuration
DATABASE_URL=postgresql://video_doc:password@localhost:5432/video_doc_db
REDIS_URL=redis://localhost:6379/0

# Application Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here-change-this-in-production

# Processing Configuration
MAX_CONCURRENT_JOBS=3
JOB_TIMEOUT=3600
MAX_FILE_SIZE=1073741824

# Authentication Configuration
SESSION_DURATION_HOURS=8
ACCOUNT_LOCKOUT_MINUTES=5
MAX_FAILED_LOGIN_ATTEMPTS=10

# Monitoring Configuration
ENABLE_METRICS=True
ENABLE_HEALTH_CHECKS=True

# Search Configuration
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2
TRANSLATION_MODEL=facebook/mbart-large-50-many-to-many-mmt

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# File Storage Configuration
UPLOAD_FOLDER=uploads
OUTPUT_FOLDER=web_outputs
STATIC_FOLDER=static

# Security Configuration
BCRYPT_ROUNDS=12
JWT_SECRET_KEY=your-jwt-secret-key-here
API_KEY_LENGTH=32

# External Service Configuration
# Add any external API keys or service configurations here